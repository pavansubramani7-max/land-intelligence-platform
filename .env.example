# ============================================================
# Land Intelligence Platform — Environment Variables
# Copy to backend/.env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=sqlite:///./landiq.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://landuser:landpass@localhost:5432/landdb

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
SECRET_KEY=super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OTP / Email ---
OTP_EXPIRE_MINUTES=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- ML Models ---
MODELS_DIR=../models
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- Twilio (optional, for phone OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Debug ---
DEBUG=true

# ============================================================
# Frontend (.env.local in frontend/)
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# Docker / Production
# ============================================================
POSTGRES_DB=landdb
POSTGRES_USER=landuser
POSTGRES_PASSWORD=your_secure_password
GRAFANA_PASSWORD=your_grafana_password
AWS_REGION=ap-south-1
AWS_ECR_REGISTRY=your_account_id.dkr.ecr.ap-south-1.amazonaws.com
